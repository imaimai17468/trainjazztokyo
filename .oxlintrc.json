{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "jsx-a11y", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "eqeqeq": "error",
    "no-var": "error",
    "no-debugger": "error",
    "guard-for-in": "error",
    "no-for-in-array": "error",
    "no-param-reassign": "error",
    "prefer-const": "warn",
    "no-console": "warn",
    "complexity": ["warn", { "max": 15 }],
    "max-depth": ["warn", { "max": 3 }],
    "max-params": ["warn", { "max": 4 }],
    "max-lines-per-function": ["warn", { "max": 130 }],
    "max-nested-callbacks": ["warn", { "max": 3 }],
    "prefer-readonly": "warn",
    "alt-text": "error",
    "anchor-has-content": "error",
    "anchor-is-valid": "error",
    "aria-props": "error",
    "aria-proptypes": "error",
    "aria-role": "error",
    "aria-unsupported-elements": "error",
    "click-events-have-key-events": "warn",
    "heading-has-content": "error",
    "html-has-lang": "error",
    "iframe-has-title": "error",
    "no-access-key": "warn",
    "no-aria-hidden-on-focusable": "error",
    "no-distracting-elements": "error",
    "no-redundant-roles": "warn",
    "role-has-required-aria-props": "error",
    "role-supports-aria-props": "error",
    "scope": "error",
    "prefer-tag-over-role": "off"
  },
  "env": {
    "browser": true,
    "builtin": true
  }
}
